{% comment %}CAHPS Appointments → Healthcare MDM Input{% endcomment %}
{% assign p = msg %}
{
  "identifiers": [
    {
      "system": "urn:{{ p.source_uri }}:patient-id",
      "value": "{{ p.patient_id }}"
    }{% if p.enterprise_id and p.enterprise_id != "" %},
    {
      "system": "urn:{{ p.source_uri }}:enterprise-id",
      "value": "{{ p.enterprise_id }}"
    }{% endif %}
  ],
  {% assign space_parts = p.patient_name | split: " " %}
  {% if space_parts.size > 1 %}
  "given_name": "{{ space_parts | first }}",
  "family_name": "{{ space_parts | last }}",
  {% else %}
  "family_name": "{{ p.patient_name | strip }}",
  {% endif %}
  {% if p.patientdob and p.patientdob != "" %}"birth_date": "{{ p.patientdob | parse_date: "{M}/{D}/{YYYY}" }}",{% endif %}
  {% if p.patient_mobile_no and p.patient_mobile_no != "" %}"phone": "{{ p.patient_mobile_no }}",{% endif %}
  "gender": "unknown"
}
