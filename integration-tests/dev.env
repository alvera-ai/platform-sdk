# Vitest integration-tests — committed dev credentials (test-only).
#
# These match the seeded root admin in config/dev.exs (admin_user) and have
# zero production exposure. Safe to commit. Per-developer overrides live in
# {local,demo,prod}.env which are gitignored.

# Environment selection (local | demo | prod). Default if unset: local.
ALVERA_ENV=local

# Root admin — seeded by priv/repo/seed_migrations/20250725124618_add_admin_user.exs
# Password mirrors config :platform, :admin_user, password: "devpassword"
ALVERA_TEST_ROOT_EMAIL=admin@dev.local
ALVERA_TEST_ROOT_PASSWORD=devpassword

# Per-industry admin user. Suffixed with -{runId}-{industry} at bootstrap.
ALVERA_TEST_ADMIN_EMAIL_PREFIX=vitest-admin
ALVERA_TEST_ADMIN_PASSWORD=devpassword123

# Per-industry tenant. Suffixed with " {runId}" + capitalized industry.
ALVERA_TEST_TENANT_PREFIX=Vitest E2E

# Ollama model used by AI-agent specs. Must be pulled locally; bootstrap
# preflight fails fast if not.
ALVERA_TEST_OLLAMA_MODEL=gemma4:latest
